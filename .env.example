# Copy to .env and fill in values.

# ── AI Feedback (free, no credit card) ───────────────────────────────────────
# Primary: Groq — get free key at https://console.groq.com
GROQ_API_KEY=

# Fallback: Google Gemini Flash-Lite — get free key at https://aistudio.google.com
GEMINI_API_KEY=

# ── Supabase (free tier) ──────────────────────────────────────────────────────
# Get these from your Supabase project: Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ── faster-whisper (transcription) ───────────────────────────────────────────
# Model size: tiny / base / small / medium / large-v3
# "small" is a good CPU default for French. Use "base" on weak machines.
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ── CORS ─────────────────────────────────────────────────────────────────────
# Production: set to your Vercel domain, e.g. https://french-coach.vercel.app
# Development: use * or http://localhost:5500
CORS_ORIGINS=*
